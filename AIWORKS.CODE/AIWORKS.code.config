# ============================================================
#  AIWORKS.CODE - Configuration File
#  형식: INI-style (Key = Value), # 주석 지원
# ============================================================

[AI]
# AI 제공자: claude | openai | custom
Provider   = claude

# ── Claude (Anthropic) ──────────────────────────────────────
# Endpoint
Endpoint   = 
# Anthropic API 키 (https://platform.claude.com/settings/keys 에서 발급)
ApiKey     = 
# Anthropic API 버전 헤더
AnthropicVersion = 2023-06-01
# 사용할 모델 (최신: claude-opus-4-6 / claude-sonnet-4-6 / claude-haiku-4-5-20251001)
Model      = claude-sonnet-4-6
# 최대 출력 토큰 수 (Opus: 128k, Sonnet/Haiku: 64k)
MaxTokens  = 4096
# 응답 타임아웃 (초)
TimeoutSec = 60
# 시스템 프롬프트 (에이전트 역할 정의)
SystemPrompt = You are AIWORKS, a local AI agent running on Windows PowerShell. You control office applications, browsers, and files on behalf of the user. Always respond in JSON with fields: action, params, message, requires_confirmation. Action types: answer, office, hwp, ie, chrome, pdf, shell.

[Browser]
# ChromeDriver 경로 (Selenium 사용 시)
ChromeDriverPath = C:\drivers\chromedriver.exe
# Playwright CLI 호출 명령 (Node.js 설치 필요)
PlaywrightCLI    = npx playwright
# Chrome 실행 파일 경로
ChromeExePath    = C:\Program Files\Google\Chrome\Application\chrome.exe
# IE 실행 여부 (레거시 호환)
EnableIE         = true

[Office]
# 한글(HWP) 보안모듈 허용 경로
HwpSecurityPath  = C:\Users\Public\Documents\HNCPaper\hwp
# PDF 텍스트 추출 도구 경로 (pdftotext 또는 별도 CLI)
PdfExtractTool   = pdftotext
# PDF 도구 전체 경로 (비어있으면 PATH에서 탐색)
PdfToolPath      =
# Office COM 초기화 대기 시간 (밀리초)
ComInitDelayMs   = 1500

[Safety]
# 자동 승인 없이 항상 확인 요구할 작업 키워드 (쉼표 구분)
ConfirmKeywords  = delete,결제,payment,drop,format,remove,rm,shutdown
# 위험 작업 로그 저장 여부
LogDangerousActions = true
# 로그 파일 경로
LogPath          = .\aiworks.log

[UI]
# 프롬프트 표시 문자열
Prompt           = AIWORKS
# Thinking 애니메이션 활성화
ShowThinking     = true
# 컬러 출력 활성화
ColorOutput      = true
# 대화 히스토리 최대 유지 수 (메모리 관리)
MaxHistory       = 20

[Programs]
# 제어할 프로그램 이름 = 실행 파일 전체 경로
# 형식: <이름> = <경로>  (이름은 AI 명령에서 참조됨)
Excel      = C:\Program Files\Microsoft Office\root\Office16\EXCEL.EXE
Word       = C:\Program Files\Microsoft Office\root\Office16\WINWORD.EXE
PowerPoint = C:\Program Files\Microsoft Office\root\Office16\POWERPNT.EXE
HWP        = C:\Program Files (x86)\HNC\Office NEO\HOffice9\Bin\Hwp.exe
Chrome     = C:\Program Files\Google\Chrome\Application\chrome.exe
Edge       = C:\Program Files (x86)\Microsoft\Edge\Application\msedge.exe
Notepad    = C:\Windows\System32\notepad.exe

[Warnings]
# 작업 키워드별 사용자 경고 메시지
# 형식: <키워드> = <경고 메시지>  (키워드는 ConfirmKeywords와 연동됨)
delete     = 파일 또는 데이터를 영구 삭제합니다. 이 작업은 되돌릴 수 없습니다.
결제       = 실제 결제가 발생할 수 있는 페이지입니다. 금액을 반드시 확인하세요.
payment    = A payment action is about to be triggered. Please verify the amount.
format     = 드라이브 또는 셀 포맷이 실행됩니다. 기존 데이터가 손실될 수 있습니다.
shutdown   = 시스템 종료 명령입니다. 저장되지 않은 작업이 있으면 먼저 저장하세요.
remove     = 항목을 제거합니다. 복구가 불가능할 수 있습니다.
drop       = 데이터베이스 테이블 또는 구조가 삭제됩니다. 신중하게 진행하세요.
